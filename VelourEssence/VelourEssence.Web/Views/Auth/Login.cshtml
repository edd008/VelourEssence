@using Microsoft.Extensions.Localization
@inject IStringLocalizer<VelourEssence.Web.Views.Auth.Login> L
@model VelourEssence.Application.DTOs.LoginDto

@{
    ViewData["Title"] = L["LoginTitle"];
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/auth-login.css" />
}

<div class="login-page">
    <!-- Fondo decorativo -->
    <div class="login-background-decoration"></div>

    <!-- Container principal -->
    <div class="login-container">
        <div class="login-wrapper">
            <!-- Header del login -->
            <div class="login-header">
                <div class="login-logo">
                    <i class="bi bi-shield-lock"></i>
                </div>
                <h1 class="login-title">@L["LoginWelcome"]</h1>
                <p class="login-subtitle">@L["LoginSubtitle"]</p>
            </div>

            <!-- Formulario de login -->
            <div class="login-form-container">
                <form asp-action="Login" asp-controller="Auth" method="post" class="login-form" id="loginForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />

                    <!-- Campo de email/usuario -->
                    <div class="login-form-group">
                        <label asp-for="EmailOUsuario" class="login-form-label">
                            <i class="bi bi-person"></i>
                            <span>@L["LoginEmailOrUser"]</span>
                        </label>
                        <div class="login-input-wrapper">
                            <input asp-for="EmailOUsuario"
                                   class="login-form-input"
                                   placeholder="@L["LoginEmailOrUserPlaceholder"]"
                                   autocomplete="username" />
                            <span asp-validation-for="EmailOUsuario" class="login-form-error"></span>
                        </div>
                    </div>

                    <!-- Campo de contraseña -->
                    <div class="login-form-group">
                        <label asp-for="Contraseña" class="login-form-label">
                            <i class="bi bi-lock"></i>
                            <span>@L["LoginPassword"]</span>
                        </label>
                        <div class="login-input-wrapper">
                            <input asp-for="Contraseña"
                                   type="password"
                                   class="login-form-input login-password-input"
                                   placeholder="@L["LoginPasswordPlaceholder"]"
                                   autocomplete="current-password" />
                            <button type="button" class="login-password-toggle" id="togglePassword">
                                <i class="bi bi-eye"></i>
                            </button>
                            <span asp-validation-for="Contraseña" class="login-form-error"></span>
                        </div>
                    </div>

                    <!-- Opciones adicionales -->
                    <div class="login-options">
                        <div class="login-remember">
                            <label class="login-checkbox-label">
                                <input asp-for="RecordarMe" type="checkbox" class="login-checkbox" />
                                <span class="login-checkbox-custom"></span>
                                <span class="login-checkbox-text">@L["LoginRememberMe"]</span>
                            </label>
                        </div>
                        <a asp-action="ForgotPassword" asp-controller="Auth" class="login-forgot-link">@L["LoginForgotPassword"]</a>
                    </div>

                    <!-- Errores generales -->
                    <div asp-validation-summary="ModelOnly" class="login-validation-summary"></div>

                    <!-- Botón de login -->
                    <button type="submit" class="login-btn-submit" id="submitBtn">
                        <i class="bi bi-box-arrow-in-right"></i>
                        <span>@L["LoginBtn"]</span>
                    </button>
                </form>

                <!-- Divider -->
                <div class="login-divider">
                    <span>@L["LoginOr"]</span>
                </div>

                <!-- Link para registro -->
                <div class="login-register-section">
                    <p class="login-register-text">@L["LoginNoAccount"]</p>
                    <a asp-action="Register" asp-controller="Auth" class="login-register-link">
                        <i class="bi bi-person-plus"></i>
                        <span>@L["LoginCreateAccount"]</span>
                    </a>
                </div>
            </div>

            <!-- Footer del login -->
            <div class="login-footer">
                <p class="login-footer-text">
                    @L["LoginAcceptTerms"]
                    <a href="#" class="login-footer-link">@L["LoginTerms"]</a> @L["LoginAnd"]
                    <a href="#" class="login-footer-link">@L["LoginPrivacy"]</a>
                </p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Toggle de contraseña
            const togglePassword = document.getElementById('togglePassword');
            const passwordInput = document.querySelector('.login-password-input');

            if (togglePassword && passwordInput) {
                togglePassword.addEventListener('click', function() {
                    const type = passwordInput.getAttribute('type') === 'password' ? 'text' : 'password';
                    passwordInput.setAttribute('type', type);

                    const icon = this.querySelector('i');
                    icon.classList.toggle('bi-eye');
                    icon.classList.toggle('bi-eye-slash');
                });
            }

            // Animación del botón de envío
            const submitBtn = document.getElementById('submitBtn');
            const form = document.getElementById('loginForm');

            if (form && submitBtn) {
                form.addEventListener('submit', function() {
                    submitBtn.classList.add('loading');
                    submitBtn.disabled = true;
                    submitBtn.innerHTML = '<i class="bi bi-hourglass-split"></i><span>' + '@L["LoginBtnLoading"]' + '</span>';
                });
            }

            // Auto-focus al primer campo
            const firstInput = document.querySelector('.login-form-input');
            if (firstInput) {
                firstInput.focus();
            }

            // Animación de entrada
            const wrapper = document.querySelector('.login-wrapper');
            if (wrapper) {
                setTimeout(() => {
                    wrapper.classList.add('animate-in');
                }, 100);
            }
        });
    </script>
}
