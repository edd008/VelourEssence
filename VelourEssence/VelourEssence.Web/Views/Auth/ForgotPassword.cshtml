@{
    ViewData["Title"] = "Restablecer contraseña";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
@section Styles {
    <link rel="stylesheet" href="~/css/forgot-password.css" />
}

<div class="forgot-password-page">
    <div class="forgot-password-container">
        <h2 class="forgot-password-title">¿Olvidaste tu contraseña?</h2>
        <p class="forgot-password-desc">Ingresa tu correo electrónico y si existe en el sistema podrás cambiar tu contraseña de inmediato.</p>
        @if (ViewBag.Message != null) {
            <div class="success-message">@ViewBag.Message</div>
        }
        <form asp-action="ForgotPassword" asp-controller="Auth" method="post" class="forgot-password-form" autocomplete="off">
            <div class="form-group">
                <label for="Email">Correo electrónico</label>
                <input type="email" name="Email" id="Email" class="form-control" required placeholder="Tu correo electrónico" />
                @Html.ValidationMessage("Email", new { @class = "text-danger" })
            </div>
            <button type="submit" class="btn btn-primary">Continuar</button>
        </form>
        <a href="@Url.Action("Login", "Auth")" class="back-to-login">Volver al login</a>
    </div>
</div>
