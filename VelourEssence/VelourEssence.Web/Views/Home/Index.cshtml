        </div>

        <div class="home-product-card">
            <div class="home-product-badge trending">@L["ProductBadgeTrending"]</div>
            <div class="home-product-image">
                <img src="https://wallpapercave.com/wp/wp13895069.jpg" alt="Valentino Uomo">
                <div class="home-product-overlay">
                    <a href="#" class="home-product-quick-view">
                        <i class="bi bi-eye"></i>
                        @L["ProductQuickView"]
                    </a>
                </div>
            </div>
            <div class="home-product-info">
                <h3 class="home-product-title">Valentino Uomo</h3>
                <p class="home-product-description">Elegancia sofisticada con bergamota, café tostado y cuero para el hombre moderno.</p>
                <div class="home-product-rating">
                    <i class="bi bi-star-fill"></i>
                    <i class="bi bi-star-fill"></i>
                    <i class="bi bi-star-fill"></i>
                    <i class="bi bi-star-fill"></i>
                    <i class="bi bi-star-fill"></i>
                    <span>(5.0)</span>
                </div>
                <div class="home-product-price">
                    <span class="price">₡75,000</span>
                </div>
                <a href="#" class="home-product-btn">
                    <i class="bi bi-cart-plus"></i>
                    @L["ProductBtnAddToCart"]
                </a>
            </div>
        </div>

        <div class="home-product-card">
            <div class="home-product-badge bestseller">@L["ProductBadgeBestSeller"]</div>
            <div class="home-product-image">
                <img src="https://fimgs.net/images/secundar/o.54358.jpg" alt="Bleu de Chanel">
                <div class="home-product-overlay">
                    <a href="#" class="home-product-quick-view">
                        <i class="bi bi-eye"></i>
                        @L["ProductQuickView"]
                    </a>
                </div>
            </div>
            <div class="home-product-info">
                <h3 class="home-product-title">Bleu de Chanel</h3>
                <p class="home-product-description">Aroma amaderado-aromático con pomelo, incienso y sándalo. Símbolo de elegancia.</p>
                <div class="home-product-rating">
                    <i class="bi bi-star-fill"></i>
                    <i class="bi bi-star-fill"></i>
                    <i class="bi bi-star-fill"></i>
                    <i class="bi bi-star-fill"></i>
                    <i class="bi bi-star"></i>
                    <span>(4.6)</span>
                </div>
                <div class="home-product-price">
                    <span class="price">₡81,000</span>
                </div>
                <a href="#" class="home-product-btn">
                    <i class="bi bi-cart-plus"></i>
                    @L["ProductBtnAddToCart"]
                </a>
            </div>
        </div>
    </div>

    <div class="home-products-cta">
        <a href="/Producto" class="home-view-all-btn">
            @L["ProductsCtaBtn"]
            <i class="bi bi-arrow-right"></i>
        </a>
    </div>
</div>

<!-- Sección de Popularidad y Contacto -->
<div class="home-features-section">
    <div class="home-features-grid">
        <!-- Lista de perfumes populares mejorada -->
        <div class="home-popular-section">
            <div class="home-popular-header">
                <h3 class="home-popular-title">
                    <i class="bi bi-fire"></i>
                    @L["PopularTitle"]
                </h3>
                <p class="home-popular-subtitle">@L["PopularSubtitle"]</p>
            </div>
            <div class="home-popular-list">
                <div class="home-popular-item trending">
                    <div class="home-popular-rank">#1</div>
                    <div class="home-popular-info">
                        <span class="home-popular-name">Dior Sauvage Eau de Parfum</span>
                        <span class="home-popular-trend">↗ +15%</span>
                    </div>
                </div>
                <div class="home-popular-item">
                    <div class="home-popular-rank">#2</div>
                    <div class="home-popular-info">
                        <span class="home-popular-name">Chanel Bleu de Chanel</span>
                        <span class="home-popular-trend">↗ +8%</span>
                    </div>
                </div>
                <div class="home-popular-item">
                    <div class="home-popular-rank">#3</div>
                    <div class="home-popular-info">
                        <span class="home-popular-name">Versace Eros</span>
                        <span class="home-popular-trend">→ 0%</span>
                    </div>
                </div>
                <div class="home-popular-item">
                    <div class="home-popular-rank">#4</div>
                    <div class="home-popular-info">
                        <span class="home-popular-name">Paco Rabanne Invictus</span>
                        <span class="home-popular-trend">↗ +5%</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Tarjeta de contacto mejorada -->
        <div class="home-contact-section">
            <div class="home-contact-card">
                <div class="home-contact-icon">
                    <i class="bi bi-headset"></i>
                </div>
                <h3 class="home-contact-title">@L["ContactTitle"]</h3>
                <p class="home-contact-text">
                    @L["ContactText"]
                </p>
                <div class="home-contact-features">
                    <div class="home-contact-feature">
                        <i class="bi bi-clock"></i>
                        <span>@L["ContactFeature1"]</span>
                    </div>
                    <div class="home-contact-feature">
                        <i class="bi bi-shield-check"></i>
                        <span>@L["ContactFeature2"]</span>
                    </div>
                    <div class="home-contact-feature">
                        <i class="bi bi-truck"></i>
                        <span>@L["ContactFeature3"]</span>
                    </div>
                </div>
                <a href="/contacto" class="home-contact-btn">
                    <i class="bi bi-chat-dots"></i>
                    @L["ContactBtn"]
                </a>
            </div>
        </div>
    </div>
</div>

<script>
    let currentSlideIndex = 0;
    const slides = document.querySelectorAll('.home-carousel-slide');
    const dots = document.querySelectorAll('.home-carousel-dot');

    function showSlide(index) {
        slides.forEach(slide => slide.classList.remove('active'));
        dots.forEach(dot => dot.classList.remove('active'));

        slides[index].classList.add('active');
        dots[index].classList.add('active');
    }

    function nextSlide() {
        currentSlideIndex = (currentSlideIndex + 1) % slides.length;
        showSlide(currentSlideIndex);
    }

    function previousSlide() {
        currentSlideIndex = (currentSlideIndex - 1 + slides.length) % slides.length;
        showSlide(currentSlideIndex);
    }

    function currentSlide(index) {
        currentSlideIndex = index - 1;
        showSlide(currentSlideIndex);
    }

    // Auto-slide cada 7 segundos (más tiempo para leer)
    setInterval(nextSlide, 7000);

    // Smooth scroll para el botón del hero
    document.addEventListener('DOMContentLoaded', function() {
        const heroScrollBtn = document.querySelector('.home-hero-scroll');
        if (heroScrollBtn) {
            heroScrollBtn.addEventListener('click', function() {
                document.querySelector('#destacados').scrollIntoView({
                    behavior: 'smooth'
                });
            });
        }

        // Animaciones en scroll
        const observerOptions = {
            threshold: 0.1,
            rootMargin: '0px 0px -50px 0px'
        };

        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('animate-in');
                }
            });
        }, observerOptions);

        // Observar elementos para animación
        document.querySelectorAll('.home-product-card, .home-section-header, .home-popular-section, .home-contact-card').forEach(el => {
            observer.observe(el);
        });
    });
</script>
