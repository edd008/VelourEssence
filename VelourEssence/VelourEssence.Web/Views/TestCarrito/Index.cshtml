@{
    ViewData["Title"] = "Prueba de Carrito";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-8">
            <h2>Prueba de Funcionalidad del Carrito</h2>
            
            <div class="card mb-4">
                <div class="card-header">
                    <h5>Agregar Producto de Prueba</h5>
                </div>
                <div class="card-body">
                    <form id="formAgregarProducto">
                        <div class="row">
                            <div class="col-md-6">
                                <label for="idProducto" class="form-label">ID del Producto:</label>
                                <input type="number" id="idProducto" name="idProducto" class="form-control" value="1" min="1">
                            </div>
                            <div class="col-md-6">
                                <label for="cantidad" class="form-label">Cantidad:</label>
                                <input type="number" id="cantidad" name="cantidad" class="form-control" value="1" min="1">
                            </div>
                        </div>
                        <button type="submit" class="btn btn-primary mt-3">Agregar al Carrito</button>
                    </form>
                </div>
            </div>

            <div class="card mb-4">
                <div class="card-header">
                    <h5>Verificar Estado del Carrito</h5>
                </div>
                <div class="card-body">
                    <button type="button" id="btnVerificarCarrito" class="btn btn-info">Verificar Carrito</button>
                    <div id="estadoCarrito" class="mt-3"></div>
                </div>
            </div>

            <div class="card">
                <div class="card-header">
                    <h5>Ir al Carrito Completo</h5>
                </div>
                <div class="card-body">
                    <a href="@Url.Action("Index", "Carrito")" class="btn btn-success">Ver Carrito</a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card">
                <div class="card-header">
                    <h5>Log de Resultados</h5>
                </div>
                <div class="card-body">
                    <div id="logResultados" style="height: 400px; overflow-y: auto; background-color: #f8f9fa; padding: 10px; border-radius: 5px;">
                        <p><strong>Log de actividades:</strong></p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
$(document).ready(function() {
    // Función para agregar logs
    function agregarLog(mensaje, tipo = 'info') {
        const timestamp = new Date().toLocaleTimeString();
        const color = tipo === 'success' ? 'text-success' : tipo === 'error' ? 'text-danger' : 'text-info';
        $('#logResultados').append(`<p class="${color}"><strong>[${timestamp}]</strong> ${mensaje}</p>`);
        $('#logResultados').scrollTop($('#logResultados')[0].scrollHeight);
    }

    // Agregar producto al carrito
    $('#formAgregarProducto').on('submit', function(e) {
        e.preventDefault();
        
        const idProducto = $('#idProducto').val();
        const cantidad = $('#cantidad').val();
        
        agregarLog(`Intentando agregar producto ${idProducto} con cantidad ${cantidad}...`);
        
        $.post('@Url.Action("AgregarProductoPrueba", "TestCarrito")', {
            idProducto: idProducto,
            cantidad: cantidad,
            __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
        })
        .done(function(result) {
            if (result.success) {
                agregarLog(`✅ ${result.message} (Cantidad total: ${result.cantidadTotal})`, 'success');
            } else {
                agregarLog(`❌ ${result.message}`, 'error');
            }
        })
        .fail(function(xhr, status, error) {
            agregarLog(`❌ Error en la petición: ${error}`, 'error');
            console.error('Error:', xhr.responseText);
        });
    });

    // Verificar estado del carrito
    $('#btnVerificarCarrito').on('click', function() {
        agregarLog('Verificando estado del carrito...');
        
        $.get('@Url.Action("VerificarCarrito", "TestCarrito")')
        .done(function(result) {
            if (result.error) {
                agregarLog(`❌ ${result.error}`, 'error');
            } else {
                const mensaje = `📊 Carrito ID: ${result.idCarrito}, Productos: ${result.productos}, Personalizados: ${result.productosPersonalizados}, Total: ${result.cantidadTotal}`;
                agregarLog(mensaje, 'success');
                
                $('#estadoCarrito').html(`
                    <div class="alert alert-info">
                        <strong>Estado del Carrito:</strong><br>
                        ID: ${result.idCarrito}<br>
                        Productos regulares: ${result.productos}<br>
                        Productos personalizados: ${result.productosPersonalizados}<br>
                        Cantidad total: ${result.cantidadTotal}
                    </div>
                `);
            }
        })
        .fail(function(xhr, status, error) {
            agregarLog(`❌ Error al verificar carrito: ${error}`, 'error');
            console.error('Error:', xhr.responseText);
        });
    });

    // Verificar carrito al cargar la página
    $('#btnVerificarCarrito').click();
});
</script>

@Html.AntiForgeryToken()
